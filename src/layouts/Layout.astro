---
const { title } = Astro.props;
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="ProFlow IA - Nodo de Inteligencia desde Costa Rica" />
    <title>{title} | ProFlow IA</title>
    <style is:global>
      :root { --primary: #38bdf8; --bg: #020617; --card: #0f172a; --text: #f1f5f9; }
      body { 
        background: var(--bg); 
        color: var(--text); 
        font-family: 'Segoe UI', system-ui, sans-serif; 
        margin: 0;
        line-height: 1.6;
      }
      article {
        max-width: 800px;
        margin: 40px auto;
        padding: 40px;
        background: var(--card);
        border: 1px solid #1e293b;
        border-radius: 20px;
      }
      article h1, article h2 { color: var(--primary); border-bottom: 1px solid #1e293b; padding-bottom: 10px; }
      article p { margin-bottom: 20px; font-size: 1.1rem; color: #cbd5e1; }
      .glass { 
        background: rgba(15, 23, 42, 0.9); 
        backdrop-filter: blur(12px); 
        border: 1px solid rgba(56, 189, 248, 0.2); 
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
