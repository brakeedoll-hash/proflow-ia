---
const { frontmatter } = Astro.props;
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>{frontmatter.title} | ProFlow IA</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      body { background: #020617; color: #f8fafc; font-family: system-ui, sans-serif; line-height: 1.6; margin: 0; }
      
      /* Navegación mejorada para AdSense */
      nav { background: #0f172a; padding: 1.2rem; border-bottom: 1px solid #1e293b; text-align: center; sticky: top; }
      nav a { color: #38bdf8; text-decoration: none; font-weight: bold; margin: 0 12px; font-size: 0.95rem; transition: 0.3s; }
      nav a:hover { color: #7dd3fc; text-shadow: 0 0 8px #38bdf8; }
      
      article { max-width: 850px; margin: 40px auto; padding: 35px; background: #0f172a; border-radius: 16px; border: 1px solid #1e293b; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
      h1 { color: #38bdf8; font-size: 2.6rem; margin-top: 0; line-height: 1.2; }
      h2 { color: #7dd3fc; margin-top: 2rem; border-bottom: 1px solid #1e293b; padding-bottom: 10px; }
      
      footer { margin-top: 60px; padding: 40px; border-top: 1px solid #1e293b; text-align: center; color: #64748b; font-size: 0.9rem; background: #020617; }
      .legal-links { margin-top: 15px; }
      .legal-links a { color: #475569; text-decoration: none; margin: 0 10px; font-size: 0.8rem; }
      .legal-links a:hover { color: #38bdf8; }
    </style>
  </head>
  <body>
    <nav>
      <a href="/">🏠 Inicio</a>
      <a href="/herramientas">🛠️ IA Tools</a>
      <a href="/nosotros">👨‍💻 Autor</a>
      <a href="/contacto">📧 Contacto</a>
      <a href="/privacidad">⚖️ Privacidad</a>
    </nav>

    <article>
      {frontmatter.title && <h1>{frontmatter.title}</h1>}
      {frontmatter.fecha && <p style="color: #64748b; font-size: 0.85rem;">Publicado el: {frontmatter.fecha}</p>}
      
      <slot /> 
    </article>

    <footer>
      <p>© 2026 ProFlow IA - Anthonny Jesus Loaiza Acevedo</p>
      <div class="legal-links">
        <a href="/privacidad">Privacidad</a> • 
        <a href="/contacto">Contacto</a> • 
        <a href="/nosotros">Sobre el Proyecto</a>
      </div>
    </footer>
  </body>
</html>
