---
// 1. Buscamos las noticias con una ruta más flexible
let posts = [];
try {
  const allPosts = import.meta.glob('./herramientas/*.md', { eager: true });
  posts = Object.values(allPosts);
  
  if (posts.length > 0) {
    posts.sort((a, b) => {
      const dateA = new Date(a.frontmatter.fecha.split('/').reverse().join('-'));
      const dateB = new Date(b.frontmatter.fecha.split('/').reverse().join('-'));
      return dateB - dateA;
    });
  }
} catch (e) {
  posts = [];
}
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>ProFlow IA | El Directorio Automático</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      body { background: #020617; color: white; font-family: 'Segoe UI', sans-serif; margin: 0; padding: 0; }
      
      /* Navegación / Botones de Inicio */
      nav { background: #0f172a; padding: 15px; border-bottom: 1px solid #1e293b; display: flex; justify-content: center; gap: 20px; }
      nav a { color: #38bdf8; text-decoration: none; font-weight: bold; padding: 8px 16px; border-radius: 8px; transition: 0.3s; }
      nav a:hover { background: #1e293b; }

      .container { max-width: 1000px; margin: 40px auto; padding: 0 20px; }
      h1 { color: #38bdf8; text-align: center; font-size: 2.5rem; margin-bottom: 5px; }
      .subtitle { text-align: center; color: #64748b; margin-bottom: 40px; }
      
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 25px; }
      .card { background: #0f172a; padding: 25px; border-radius: 16px; border: 1px solid #1e293b; text-decoration: none; color: white; transition: 0.3s; display: flex; flex-direction: column; }
      .card:hover { border-color: #38bdf8; transform: translateY(-5px); }
      .badge { background: #0ea5e9; font-size: 0.7rem; padding: 4px 10px; border-radius: 50px; font-weight: bold; color: #020617; width: fit-content; }
      .date { color: #64748b; font-size: 0.8rem; margin-top: 15px; padding-top: 10px; border-top: 1px solid #1e293b; }

      /* Chat Flotante */
      #chat-box { position: fixed; bottom: 20px; right: 20px; width: 320px; background: #0f172a; border: 1px solid #38bdf8; border-radius: 12px; display: flex; flex-direction: column; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
      #chat-head { background: #38bdf8; color: #020617; padding: 10px; font-weight: bold; border-radius: 10px 10px 0 0; }
      #chat-content { height: 250px; overflow-y: auto; padding: 10px; font-size: 0.9rem; }
      #chat-input-wrapper { display: flex; padding: 10px; gap: 5px; border-top: 1px solid #1e293b; }
      #chat-input { flex: 1; background: #020617; border: 1px solid #1e293b; color: white; padding: 5px; border-radius: 5px; }
      #chat-btn { background: #38bdf8; border: none; padding: 5px 10px; border-radius: 5px; cursor: pointer; }
    </style>
  </head>
  <body>
    <nav>
      <a href="/">Inicio</a>
      <a href="/nosotros">Nosotros</a>
      <a href="/contacto">Contacto</a>
    </nav>

    <div class="container">
      <h1>🚀 ProFlow IA</h1>
      <p class="subtitle">Noticias reales de tecnología para la U</p>

      <div class="grid">
        {posts.length > 0 ? (
          posts.map(post => (
            <a href={post.url} class="card">
              <span class="badge">NOTICIA</span>
              <h2>{post.frontmatter.title}</h2>
              <div class="date">📅 {post.frontmatter.fecha}</div>
            </a>
          ))
        ) : (
          <p style="text-align:center; grid-column: 1/-1;">No hay noticias aún. Revisa la carpeta herramientas.</p>
        )}
      </div>
    </div>

    <div id="chat-box">
      <div id="chat-head">🤖 Asistente ProFlow</div>
      <div id="chat-content">
        <div>¡Hola! Pregúntame lo que quieras.</div>
      </div>
      <div id="chat-input-wrapper">
        <input type="text" id="chat-input" placeholder="Escribe..." />
        <button id="chat-btn">-></button>
      </div>
    </div>

    <script>
      const btn = document.getElementById('chat-btn');
      const input = document.getElementById('chat-input');
      const content = document.getElementById('chat-content');

      btn.onclick = async () => {
        const val = input.value;
        if(!val) return;
        content.innerHTML += `<div><b>Tú:</b> ${val}</div>`;
        input.value = '';
        
        try {
          const res = await fetch('/api/v2-chat', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ message: val })
          });
          const data = await res.json();
          content.innerHTML += `<div><b>IA:</b> ${data.response || data.error}</div>`;
        } catch(e) {
          content.innerHTML += `<div style="color:red">Error de conexión</div>`;
        }
      }
    </script>
  </body>
</html>
