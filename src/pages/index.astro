---
// Lógica corregida para encontrar las noticias en la carpeta herramientas
let posts = [];
try {
  // Buscamos los archivos .md dentro de la carpeta herramientas
  const allPosts = import.meta.glob('./herramientas/*.md', { eager: true });
  posts = Object.values(allPosts);
  
  // Ordenar por fecha (más reciente primero)
  if (posts.length > 0) {
    posts.sort((a, b) => {
      const dateA = new Date(a.frontmatter.fecha.split('/').reverse().join('-'));
      const dateB = new Date(b.frontmatter.fecha.split('/').reverse().join('-'));
      return dateB - dateA;
    });
  }
} catch (e) {
  console.error("Error cargando noticias:", e);
  posts = []; 
}
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>ProFlow IA | El Directorio Automático</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      body { background: #020617; color: white; font-family: 'Segoe UI', system-ui, sans-serif; padding: 20px; margin: 0; }
      .container { max-width: 1000px; margin: 40px auto; padding: 0 20px; }
      h1 { color: #38bdf8; text-align: center; margin-bottom: 10px; font-size: 2.5rem; }
      p.subtitle { text-align: center; color: #64748b; margin-bottom: 50px; }
      
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 25px; }
      .card { background: #0f172a; padding: 25px; border-radius: 16px; border: 1px solid #1e293b; text-decoration: none; color: white; transition: all 0.3s ease; display: flex; flex-direction: column; height: 100%; box-sizing: border-box; }
      .card:hover { border-color: #38bdf8; transform: translateY(-8px); box-shadow: 0 10px 30px rgba(56, 189, 248, 0.15); }
      
      .card h2 { margin: 15px 0; color: #38bdf8; font-size: 1.4rem; line-height: 1.2; flex-grow: 1; }
      .badge { background: #0ea5e9; font-size: 0.7rem; padding: 4px 12px; border-radius: 50px; font-weight: bold; color: #020617; width: fit-content; text-transform: uppercase; }
      .date { color: #64748b; font-size: 0.85rem; margin-top: auto; border-top: 1px solid #1e293b; padding-top: 10px; display: flex; align-items: center; gap: 5px; }
      
      .empty-state { text-align: center; padding: 80px; background: #0f172a; border-radius: 20px; border: 1px dashed #334155; margin-top: 20px; }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>🚀 ProFlow IA</h1>
      <p class="subtitle">Noticias reales de tecnología generadas por IA</p>

      {posts.length > 0 ? (
        <div class="grid">
          {posts.map(post => (
            <a href={post.url} class="card">
              <span class="badge">ACTUALIDAD ⚡</span>
              <h2>{post.frontmatter.title}</h2>
              <div class="date">📅 {post.frontmatter.fecha}</div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <h2 style="color: #94a3b8;">📡 El bot está investigando...</h2>
          <p style="color: #64748b;">No se encontraron archivos en src/pages/herramientas/</p>
        </div>
      )}
    </div>
  </body>
</html>
