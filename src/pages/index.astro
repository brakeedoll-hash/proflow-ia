---
// Buscamos todos los archivos .md en la carpeta herramientas
const posts = await Astro.glob('./herramientas/*.md');
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>ProFlow IA | El Directorio Automático</title>
    <style>
      body { background: #020617; color: white; font-family: sans-serif; padding: 40px; }
      .container { max-width: 900px; margin: 0 auto; }
      h1 { color: #38bdf8; text-align: center; margin-bottom: 40px; }
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
      .card { background: #0f172a; padding: 20px; border-radius: 12px; border: 1px solid #1e293b; text-decoration: none; color: white; transition: 0.3s; }
      .card:hover { border-color: #38bdf8; transform: translateY(-5px); }
      .card h2 { margin-top: 0; color: #38bdf8; font-size: 1.2rem; }
      .badge { background: #1e293b; font-size: 0.7rem; padding: 4px 10px; border-radius: 10px; display: inline-block; margin-bottom: 10px; color: #94a3b8; }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>🚀 ProFlow IA: Directorio Automático</h1>
      <div class="grid">
        {posts.map(post => (
          <a href={post.url} class="card">
            <span class="badge">Nuevo! ⚡</span>
            <h2>{post.frontmatter.title}</h2>
            <p>Fecha: {post.frontmatter.fecha}</p>
          </a>
        ))}
      </div>
    </div>
  </body>
</html>
