---
import Layout from '../layouts/Layout.astro';
const allPosts = import.meta.glob('./herramientas/*.md', { eager: true });
const posts = Object.values(allPosts).sort((a, b) => 
  new Date(b.frontmatter.fecha) - new Date(a.frontmatter.fecha)
);
---

<Layout title="Dashboard v4.0">
  <nav class="glass" style="padding: 1rem 10%; display: flex; justify-content: space-between; position: sticky; top: 0; z-index: 50;">
    <div style="font-weight: 800; color: var(--primary); font-size: 1.4rem; letter-spacing: 2px;">PROFLOW <span style="color:white;">IA</span></div>
    <div style="display: flex; gap: 30px; align-items: center;">
      <a href="/" style="color: var(--primary); text-decoration: none; font-size: 0.8rem; font-weight: bold;">CORE_DASHBOARD</a>
      <a href="/nosotros" style="color: white; text-decoration: none; font-size: 0.8rem; opacity: 0.7;">REPORTS</a>
    </div>
  </nav>

  <main style="max-width: 1100px; margin: 4rem auto; padding: 0 20px;">
    <div style="border-left: 4px solid var(--primary); padding-left: 20px; margin-bottom: 50px;">
      <h1 style="font-size: 3rem; margin: 0; text-transform: uppercase; letter-spacing: -1px;">Central de <span style="color: var(--primary);">Hardware</span></h1>
      <p style="color: #64748b; margin-top: 5px;">Costa Rica Technical Node // Mar-2026</p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 30px;">
      {posts.map(p => (
        <a href={p.url} style="text-decoration: none;">
          <div style="background: var(--card); padding: 30px; border-radius: 24px; border: 1px solid #1e293b; transition: all 0.4s ease; height: 100%; box-sizing: border-box;" 
               onmouseover="this.style.borderColor='#38bdf8'; this.style.transform='translateY(-5px)'" 
               onmouseout="this.style.borderColor='#1e293b'; this.style.transform='translateY(0)'">
            <span style="background: rgba(56, 189, 248, 0.1); color: var(--primary); font-size: 0.65rem; padding: 4px 10px; border-radius: 4px; font-weight: bold;">ENCRIPTADO // MD</span>
            <h2 style="font-size: 1.4rem; color: white; margin: 20px 0;">{p.frontmatter.title}</h2>
            <div style="color: #64748b; font-size: 0.8rem; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #1e293b; padding-top: 15px;">
              <span>📅 {p.frontmatter.fecha}</span>
              <span style="color: var(--primary);">OPEN_DATA →</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>

  <div id="chat-widget" class="glass" style="position: fixed; bottom: 25px; right: 25px; width: 360px; border-radius: 24px; overflow: hidden; box-shadow: 0 25px 60px rgba(0,0,0,0.8); border: 1px solid rgba(56, 189, 248, 0.3);">
    <div style="background: var(--primary); color: #020617; padding: 15px 20px; font-weight: 900; font-size: 0.85rem; display: flex; justify-content: space-between; align-items: center;">
      <span>TERMINAL // PROFLOW_AI</span>
      <div style="width: 10px; height: 10px; background: #020617; border-radius: 50%; animation: pulse 1.5s infinite;"></div>
    </div>
    <div id="logs" style="height: 300px; overflow-y: auto; padding: 20px; font-family: 'Courier New', monospace; font-size: 0.85rem; background: #010409; color: #a3b3bc;">
      <div style="color: #38bdf8; margin-bottom: 10px;">> Estableciendo conexión con el núcleo...</div>
      <div style="color: #22c55e;">> ONLINE: Asistente listo.</div>
    </div>
    <div style="padding: 15px; background: #0f172a; display: flex; gap: 10px; border-top: 1px solid #1e293b;">
      <input type="text" id="prompt" placeholder="Escribir comando..." style="flex: 1; background: #020617; border: 1px solid #334155; color: #38bdf8; padding: 10px; border-radius: 10px; outline: none; font-family: monospace;" />
      <button id="send-btn" style="background: var(--primary); border: none; padding: 10px 20px; border-radius: 10px; cursor: pointer; font-weight: bold; color: #020617;">></button>
    </div>
  </div>

  <style>
    @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.3; } 100% { opacity: 1; } }
  </style>

  <script>
    const btn = document.getElementById('send-btn');
    const input = document.getElementById('prompt');
    const logs = document.getElementById('logs');

    async function executeCommand() {
      const msg = input.value.trim();
      if (!msg) return;

      // Mostrar mensaje del usuario
      logs.innerHTML += `<div style="color: #fff; margin-top: 10px;">> USER: ${msg}</div>`;
      input.value = '';
      logs.scrollTop = logs.scrollHeight;

      try {
        const response = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: msg })
        });

        const data = await response.json();
        
        if (data.response) {
          logs.innerHTML += `<div style="color: #38bdf8; margin-top: 5px;">> AI: ${data.response}</div>`;
        } else {
          logs.innerHTML += `<div style="color: #ef4444; margin-top: 5px;">> ERROR: ${data.error}</div>`;
        }
      } catch (err) {
        logs.innerHTML += `<div style="color: #ef4444; margin-top: 5px;">> CRITICAL_FAILURE: Connection lost.</div>`;
      }
      logs.scrollTop = logs.scrollHeight;
    }

    btn.addEventListener('click', executeCommand);
    input.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') executeCommand();
    });
  </script>
</Layout>
