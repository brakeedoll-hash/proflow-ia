---
let posts = [];
try {
  // Esta es la forma más compatible de buscar archivos en Astro/Vercel
  const allPosts = import.meta.glob(['./herramientas/*.md', '/src/pages/herramientas/*.md', '../pages/herramientas/*.md'], { eager: true });
  
  posts = Object.values(allPosts);

  // Ordenar: Las noticias con fecha más reciente arriba
  if (posts.length > 0) {
    posts.sort((a, b) => {
      const dateA = new Date(a.frontmatter.fecha || 0);
      const dateB = new Date(b.frontmatter.fecha || 0);
      return dateB - dateA;
    });
  }
} catch (e) {
  console.error("Fallo crítico en el núcleo:", e);
}
---

<html lang="es">
<head>
  <meta charset="utf-8" />
  <title>ProFlow IA | Core</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root { --primary: #38bdf8; --bg: #020617; --card: #0f172a; }
    body { background: var(--bg); color: white; font-family: 'Plus Jakarta Sans', sans-serif; margin: 0; overflow-x: hidden; }
    
    /* Fondo con efecto de red */
    body::before { content: ""; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-image: radial-gradient(#1e293b 1px, transparent 1px); background-size: 30px 30px; opacity: 0.3; z-index: -1; }

    nav { backdrop-filter: blur(10px); background: rgba(15, 23, 42, 0.8); padding: 1rem 10%; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #1e293b; position: sticky; top: 0; z-index: 100; }
    .logo { font-weight: 800; color: var(--primary); font-size: 1.5rem; letter-spacing: -1px; }
    
    .hero { text-align: center; padding: 5rem 1rem; }
    .hero h1 { font-size: 4rem; margin: 0; background: linear-gradient(to right, #fff, #38bdf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; filter: drop-shadow(0 0 10px rgba(56, 189, 248, 0.3)); }
    
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem; max-width: 1200px; margin: 0 auto 5rem; padding: 0 2rem; }
    .card { background: var(--card); border: 1px solid #1e293b; padding: 2rem; border-radius: 24px; transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); position: relative; overflow: hidden; }
    .card:hover { transform: translateY(-10px); border-color: var(--primary); box-shadow: 0 20px 40px rgba(0,0,0,0.4); }
    .card h2 { margin-top: 1rem; font-size: 1.4rem; color: #f1f5f9; }
    .card-link { text-decoration: none; color: inherit; }
    
    /* Glass Chat */
    #chat-widget { position: fixed; bottom: 30px; right: 30px; width: 380px; height: 500px; background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(15px); border: 1px solid rgba(56, 189, 248, 0.2); border-radius: 28px; display: flex; flex-direction: column; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); z-index: 1000; }
    .chat-header { padding: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.05); display: flex; align-items: center; gap: 10px; font-weight: bold; }
    .status-dot { width: 8px; height: 8px; background: #22c55e; border-radius: 50%; box-shadow: 0 0 10px #22c55e; }
    #messages { flex: 1; overflow-y: auto; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
    .msg { padding: 0.8rem 1.2rem; border-radius: 18px; max-width: 80%; font-size: 0.95rem; line-height: 1.5; }
    .user { background: var(--primary); color: #020617; align-self: flex-end; font-weight: 600; }
    .bot { background: #1e293b; color: #e2e8f0; align-self: flex-start; border: 1px solid rgba(255,255,255,0.05); }
    .chat-input-area { padding: 1.2rem; display: flex; gap: 10px; }
    input { flex: 1; background: #020617; border: 1px solid #1e293b; color: white; padding: 0.8rem 1.2rem; border-radius: 14px; outline: none; transition: 0.3s; }
    input:focus { border-color: var(--primary); }
    button { background: var(--primary); border: none; padding: 0.8rem 1.5rem; border-radius: 14px; cursor: pointer; font-weight: bold; transition: 0.3s; }
    button:hover { transform: scale(1.05); filter: brightness(1.1); }
  </style>
</head>
<body>
  <nav>
    <div class="logo">PROFLOW // IA</div>
    <div style="display:flex; gap: 2rem; font-size: 0.9rem; font-weight: 600;">
      <span>DASHBOARD</span>
      <span>SISTEMAS</span>
      <span>NOSOTROS</span>
    </div>
  </nav>

  <div class="hero">
    <h1>El Futuro del Hardware</h1>
    <p style="color: #64748b; font-size: 1.2rem;">Directorio inteligente de noticias procesadas en tiempo real.</p>
  </div>

  <div class="grid">
    {posts.length > 0 ? (
      posts.map(p => (
        <a href={p.url} class="card-link">
          <div class="card">
            <span style="color:var(--primary); font-size:0.7rem; font-weight:800; border: 1px solid var(--primary); padding: 2px 8px; border-radius: 4px;">SYSTEM_UPDATE</span>
            <h2>{p.frontmatter.title}</h2>
            <div style="margin-top:2rem; color:#64748b; font-size:0.8rem; display:flex; justify-content:space-between;">
              <span>📅 {p.frontmatter.fecha}</span>
              <span>READ MORE →</span>
            </div>
          </div>
        </a>
      ))
    ) : (
      <div style="grid-column: 1/-1; text-align:center; opacity: 0.5;">Esperando datos del núcleo...</div>
    )}
  </div>

  <div id="chat-widget">
    <div class="chat-header"><div class="status-dot"></div> PROFLOW_ASSISTANT v3.0</div>
    <div id="messages">
      <div class="msg bot">Terminal lista. ¿Cuál es tu consulta hoy?</div>
    </div>
    <div class="chat-input-area">
      <input type="text" id="userInput" placeholder="Ingresar comando..." />
      <button id="sendBtn">SEND</button>
    </div>
  </div>

  <script>
    const btn = document.getElementById('sendBtn');
    const input = document.getElementById('userInput');
    const messages = document.getElementById('messages');

    async function chat() {
      const text = input.value.trim();
      if(!text) return;

      messages.innerHTML += `<div class="msg user">${text}</div>`;
      input.value = '';
      messages.scrollTop = messages.scrollHeight;

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({ message: text })
        });
        const data = await res.json();
        messages.innerHTML += `<div class="msg bot">${data.response || data.error}</div>`;
      } catch {
        messages.innerHTML += `<div class="msg bot" style="color:#ef4444">CRITICAL_ERROR: Link failed.</div>`;
      }
      messages.scrollTop = messages.scrollHeight;
    }

    btn.onclick = chat;
    input.onkeypress = (e) => e.key === 'Enter' && chat();
  </script>
</body>
</html>
