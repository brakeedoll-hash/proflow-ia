---
// Lógica de importación REFORZADA para Vercel
const allPosts = import.meta.glob('./herramientas/*.md', { eager: true });
const posts = Object.values(allPosts).sort((a, b) => 
  new Date(b.frontmatter.fecha) - new Date(a.frontmatter.fecha)
);
---

<html lang="es">
<head>
  <meta charset="utf-8" />
  <title>ProFlow IA | Core</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    :root { --accent: #38bdf8; --bg: #020617; --card: #0f172a; }
    body { background: var(--bg); color: white; font-family: 'Segoe UI', sans-serif; margin: 0; }
    nav { background: rgba(15, 23, 42, 0.9); padding: 1rem 10%; display: flex; justify-content: space-between; border-bottom: 1px solid #1e293b; position: sticky; top: 0; z-index: 100; backdrop-filter: blur(10px); }
    .hero { text-align: center; padding: 4rem 1rem; background: radial-gradient(circle at center, #1e293b 0%, #020617 100%); }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem; max-width: 1100px; margin: -2rem auto 5rem; padding: 0 2rem; }
    .card { background: var(--card); border: 1px solid #1e293b; padding: 1.5rem; border-radius: 20px; transition: 0.3s; text-decoration: none; color: white; display: flex; flex-direction: column; }
    .card:hover { border-color: var(--accent); transform: translateY(-5px); box-shadow: 0 10px 30px rgba(56, 189, 248, 0.1); }
    
    /* Chat Pro */
    #chat { position: fixed; bottom: 20px; right: 20px; width: 350px; background: var(--card); border: 1px solid #1e293b; border-radius: 15px; display: flex; flex-direction: column; box-shadow: 0 20px 40px rgba(0,0,0,0.5); }
    #messages { height: 250px; overflow-y: auto; padding: 1rem; font-size: 0.9rem; }
    .input-area { display: flex; padding: 1rem; border-top: 1px solid #1e293b; gap: 10px; }
    input { flex: 1; background: #020617; border: 1px solid #334155; color: white; padding: 8px; border-radius: 8px; outline: none; }
    button { background: var(--accent); border: none; padding: 8px 15px; border-radius: 8px; font-weight: bold; cursor: pointer; }
  </style>
</head>
<body>
  <nav>
    <div style="font-weight: 800; color: var(--accent);">PROFLOW IA</div>
    <div style="display:flex; gap: 20px; font-size: 0.8rem;">
      <a href="/" style="color:white; text-decoration:none;">INICIO</a>
      <a href="/nosotros" style="color:white; text-decoration:none;">NOSOTROS</a>
    </div>
  </nav>

  <div class="hero">
    <h1 style="font-size: 3rem; margin: 0;">Sistemas de Vanguardia</h1>
    <p style="color: #64748b;">Información de hardware procesada por Inteligencia Artificial</p>
  </div>

  <div class="grid">
    {posts.length > 0 ? posts.map(p => (
      <a href={p.url} class="card">
        <span style="color:var(--accent); font-size:0.7rem; font-weight:bold;">[ ACTUALIZACIÓN ]</span>
        <h2 style="font-size: 1.2rem; margin: 10px 0;">{p.frontmatter.title}</h2>
        <div style="margin-top:auto; font-size:0.8rem; color:#64748b;">📅 {p.frontmatter.fecha}</div>
      </a>
    )) : (
      <div style="grid-column: 1/-1; text-align:center; padding: 50px;">
        <p>No se encontraron noticias. Verifica /src/pages/herramientas/</p>
      </div>
    )}
  </div>

  <div id="chat">
    <div style="background: #1e293b; padding: 10px; border-radius: 15px 15px 0 0; font-weight: bold; color: var(--accent);">🤖 Assistant v3</div>
    <div id="messages"><div>Terminal lista...</div></div>
    <div class="input-area">
      <input type="text" id="userInput" placeholder="Pregunta algo..." />
      <button id="sendBtn">></button>
    </div>
  </div>

  <script>
    const btn = document.getElementById('sendBtn');
    const input = document.getElementById('userInput');
    const box = document.getElementById('messages');

    async function chat() {
      const msg = input.value; if(!msg) return;
      box.innerHTML += `<div><b>Tú:</b> ${msg}</div>`;
      input.value = '';
      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          body: JSON.stringify({ message: msg })
        });
        const data = await res.json();
        box.innerHTML += `<div><b>IA:</b> ${data.response || data.error}</div>`;
      } catch { box.innerHTML += `<div>Error link.</div>`; }
      box.scrollTop = box.scrollHeight;
    }
    btn.onclick = chat;
    input.onkeypress = (e) => e.key === 'Enter' && chat();
  </script>
</body>
</html>
