---
import Layout from '../layouts/Layout.astro';

// Buscamos todas las noticias
const allPosts = import.meta.glob('./herramientas/*.md', { eager: true });
const posts = Object.values(allPosts).sort((a, b) => 
  new Date(b.frontmatter.fecha) - new Date(a.frontmatter.fecha)
);
---

<Layout title="Dashboard Core">
  <nav class="glass" style="padding: 1rem 10%; display: flex; justify-content: space-between; position: sticky; top: 0; z-index: 50;">
    <div style="font-weight: 800; color: var(--primary); font-size: 1.2rem;">PROFLOW // IA</div>
    <div style="display: flex; gap: 20px;">
      <a href="/" style="color: white; text-decoration: none; font-size: 0.9rem;">DASHBOARD</a>
      <a href="/nosotros" style="color: white; text-decoration: none; font-size: 0.9rem;">NOSOTROS</a>
    </div>
  </nav>

  <main style="max-width: 1100px; margin: 3rem auto; padding: 0 1rem;">
    <header style="text-align: center; margin-bottom: 4rem;">
      <h1 style="font-size: 3.5rem; margin: 0; letter-spacing: -2px;">SISTEMAS <span style="color: var(--primary);">IA</span></h1>
      <p style="color: #64748b;">Monitoreo de Hardware y Redes en Costa Rica</p>
    </header>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
      {posts.length > 0 ? posts.map(p => (
        <a href={p.url} style="text-decoration: none; color: inherit;">
          <div style="background: var(--card); padding: 2rem; border-radius: 20px; border: 1px solid #1e293b; transition: 0.3s;" onmouseover="this.style.borderColor='#38bdf8'" onmouseout="this.style.borderColor='#1e293b'">
            <small style="color: var(--primary); font-weight: bold;">[ NEWS_FEED ]</small>
            <h2 style="font-size: 1.3rem; margin: 15px 0;">{p.frontmatter.title}</h2>
            <div style="font-size: 0.8rem; color: #64748b;">📅 {p.frontmatter.fecha}</div>
          </div>
        </a>
      )) : (
        <div style="grid-column: 1/-1; text-align: center; padding: 3rem; border: 1px dashed #1e293b; border-radius: 20px; color: #64748b;">
          Esperando sincronización de datos de /herramientas/...
        </div>
      )}
    </div>
  </main>

  <div id="chat-ui" class="glass" style="position: fixed; bottom: 20px; right: 20px; width: 350px; border-radius: 20px; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.4);">
    <div style="background: var(--primary); color: #020617; padding: 12px 20px; font-weight: bold; font-size: 0.9rem;">🤖 PROFLOW_BOT v4.0</div>
    <div id="logs" style="height: 250px; overflow-y: auto; padding: 1rem; font-family: monospace; font-size: 0.85rem; display: flex; flex-direction: column; gap: 8px;">
      <div style="color: #38bdf8;">> Sistema iniciado...</div>
    </div>
    <div style="padding: 1rem; display: flex; gap: 10px; border-top: 1px solid rgba(255,255,255,0.05);">
      <input type="text" id="prompt" placeholder="Comando..." style="flex: 1; background: #020617; border: 1px solid #1e293b; color: white; padding: 8px; border-radius: 8px; outline: none;" />
      <button id="exec" style="background: var(--primary); border: none; padding: 8px 15px; border-radius: 8px; cursor: pointer; font-weight: bold;">></button>
    </div>
  </div>

  <script>
    const btn = document.getElementById('exec');
    const input = document.getElementById('prompt');
    const logs = document.getElementById('logs');

    async function send() {
      const msg = input.value; if(!msg) return;
      logs.innerHTML += `<div style="color: #fff;">> USER: ${msg}</div>`;
      input.value = '';
      logs.scrollTop = logs.scrollHeight;

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          body: JSON.stringify({ message: msg })
        });
        const data = await res.json();
        logs.innerHTML += `<div style="color: #38bdf8;">> AI: ${data.response || data.error}</div>`;
      } catch {
        logs.innerHTML += `<div style="color: #ef4444;">> ERROR: Link offline.</div>`;
      }
      logs.scrollTop = logs.scrollHeight;
    }
    btn.onclick = send;
    input.onkeypress = (e) => e.key === 'Enter' && send();
  </script>
</Layout>
