<h1>AAAAA NUEVA VERSION 777</h1>
---
import Layout from '../layouts/Layout.astro';

const allPosts = import.meta.glob('./herramientas/*.md', { eager: true });
const posts = Object.values(allPosts);

if (posts && posts.length > 0) {
  posts.sort((a, b) => {
    const dateA = new Date(a.frontmatter?.fecha || 0).getTime();
    const dateB = new Date(b.frontmatter?.fecha || 0).getTime();
    return dateB - dateA;
  });
}
---

<Layout title="Dashboard Core v4.0">
  <nav class="glass" style="padding: 1.2rem 8%; display: flex; justify-content: space-between; position: sticky; top: 0; z-index: 50; align-items: center;">
    <div style="font-weight: 900; color: var(--primary); font-size: 1.5rem; letter-spacing: 1px;">PROFLOW <span style="color:white;">IA</span></div>
    <div style="display: flex; gap: 25px;">
      <a href="/" style="color: var(--primary); text-decoration: none; font-size: 0.85rem; font-weight: bold; text-transform: uppercase;">Core_Dash</a>
      <a href="/nosotros" style="color: white; text-decoration: none; font-size: 0.85rem; opacity: 0.6; text-transform: uppercase;">Reports</a>
      <a href="/contacto" style="color: white; text-decoration: none; font-size: 0.85rem; opacity: 0.6; text-transform: uppercase;">Contacto</a>
    </div>
  </nav>

  <main style="max-width: 1200px; margin: 4rem auto; padding: 0 25px;">
    <div style="border-left: 5px solid var(--primary); padding-left: 25px; margin-bottom: 60px;">
      <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); margin: 0; text-transform: uppercase; line-height: 1;">Nodo de <span style="color: var(--primary);">Inteligencia</span></h1>
      <p style="color: #64748b; margin-top: 10px; font-family: monospace; letter-spacing: 1px;">[ STATUS: ONLINE ] // COSTA RICA // MARZO 2026</p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 35px;">
      {posts.length > 0 ? posts.map((p: any) => (
        <a href={p.url} style="text-decoration: none; color: inherit;">
          <div class="card-tech" style="background: var(--card); padding: 35px; border-radius: 28px; border: 1px solid #1e293b; transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); height: 100%; display: flex; flex-direction: column; position: relative; overflow: hidden;">
            <div style="background: rgba(56, 189, 248, 0.1); color: var(--primary); font-size: 0.7rem; padding: 5px 12px; border-radius: 6px; font-weight: 800; width: fit-content; margin-bottom: 20px;">DATA_STREAM</div>
            <h2 style="font-size: 1.5rem; margin: 0 0 25px 0; color: white; line-height: 1.3;">{p.frontmatter.title}</h2>
            <div style="margin-top: auto; padding-top: 20px; border-top: 1px solid #1e293b; display: flex; justify-content: space-between; align-items: center; color: #64748b; font-size: 0.85rem;">
              <span>📅 {p.frontmatter.fecha}</span>
              <span style="color: var(--primary); font-weight: bold;">ACCEDER →</span>
            </div>
          </div>
        </a>
      )) : (
        <div style="grid-column: 1/-1; text-align: center; padding: 80px; border: 2px dashed #1e293b; border-radius: 30px; color: #475569;">
          <p style="font-size: 1.2rem;">Sincronizando con la carpeta de noticias...</p>
        </div>
      )}
    </div>
  </main>

  <div id="chat-widget" class="glass" style="position: fixed; bottom: 30px; right: 30px; width: 380px; border-radius: 28px; overflow: hidden; box-shadow: 0 30px 70px rgba(0,0,0,0.7); border: 1px solid rgba(56, 189, 248, 0.3);">
    <div style="background: var(--primary); color: #020617; padding: 18px 25px; font-weight: 900; font-size: 0.9rem; display: flex; justify-content: space-between; align-items: center;">
      <span>CORE_TERMINAL // v4.0</span>
      <div class="pulse-dot"></div>
    </div>
    <div id="logs" style="height: 320px; overflow-y: auto; padding: 25px; font-family: 'Courier New', monospace; font-size: 0.9rem; background: #010409; color: #94a3b8; display: flex; flex-direction: column; gap: 12px;">
      <div style="color: #38bdf8;">> Iniciando protocolos de comunicación...</div>
      <div style="color: #22c55e;">> Conexión establecida con Gemini 1.5.</div>
    </div>
    <div style="padding: 18px; background: #0f172a; display: flex; gap: 12px; border-top: 1px solid #1e293b;">
      <input type="text" id="prompt" placeholder="Ingresar comando..." style="flex: 1; background: #020617; border: 1px solid #334155; color: #38bdf8; padding: 12px; border-radius: 12px; outline: none; font-family: monospace;" />
      <button id="send-btn" style="background: var(--primary); border: none; padding: 0 20px; border-radius: 12px; cursor: pointer; font-weight: bold; color: #020617;">ENVIAR</button>
    </div>
  </div>

  <style>
    .pulse-dot { width: 10px; height: 10px; background: #020617; border-radius: 50%; animation: pulse 1.5s infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.4; transform: scale(0.9); } }
    .card-tech:hover { border-color: #38bdf8 !important; transform: translateY(-8px); background: #111a2e !important; box-shadow: 0 20px 40px rgba(56, 189, 248, 0.1); }
  </style>

  <script>
    const btn = document.getElementById('send-btn');
    const input = document.getElementById('prompt') as HTMLInputElement;
    const logs = document.getElementById('logs');

    async function execute() {
      const msg = input.value.trim();
      if (!msg) return;

      logs.innerHTML += `<div style="color: #fff;">> USER: ${msg}</div>`;
      input.value = '';
      logs.scrollTop = logs.scrollHeight;

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: msg })
        });
        const data = await res.json();

        if (data.response) {
          logs.innerHTML += `<div style="color: #38bdf8;">> AI: ${data.response}</div>`;
        } else {
          logs.innerHTML += `<div style="color: #ef4444;">> ERROR: ${data.error || 'Respuesta inválida'}</div>`;
        }
      } catch (err) {
        logs.innerHTML += `<div style="color: #ef4444;">> CRITICAL_ERROR: Timeout.</div>`;
      }
      logs.scrollTop = logs.scrollHeight;
    }

    btn.addEventListener('click', execute);
    input.addEventListener('keypress', (e) => e.key === 'Enter' && execute());
  </script>
</Layout>
